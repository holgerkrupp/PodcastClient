        }
      },
      {
        "comment": "",
        "key": "Archive file retention",
        "location": {
          "startingColumn": 32,
          "startingLine": 660
        }
      },
      {
        "comment": "",
        "key": "Keeps only the selected oldest or newest unplayed episodes for this podcast downloaded on device. Optionally includes back catalog episodes from initial imports.",
