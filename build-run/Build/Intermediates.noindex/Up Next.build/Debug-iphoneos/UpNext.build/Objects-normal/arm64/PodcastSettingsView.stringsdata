      {
        "comment": "",
        "key": "This screen focuses on what is unique to this podcast. App-wide controls stay grouped under Global Settings.",
        "location": {
          "startingColumn": 22,
          "startingLine": 248
        }
      },
      {
        "comment": "",
        "key": "Using podcast-specific settings",
        "location": {
          "startingColumn": 62,
          "startingLine": 239
        }
      },
      {
        "comment": "",
        "key": "Following global defaults",
        "location": {
          "startingColumn": 98,
          "startingLine": 239
        }
      },
      {
        "comment": "",
        "key": "These values apply across the app unless a podcast is switched to custom settings.",
        "location": {
          "startingColumn": 26,
          "startingLine": 256
        }
      },
      {
        "comment": "",
        "key": "Global Defaults",
        "location": {
          "startingColumn": 27,
          "startingLine": 253
        }
      },
      {
        "comment": "",
        "key": "Use podcast-specific settings",
        "location": {
          "startingColumn": 17,
          "startingLine": 268
        }
      },
      {
        "comment": "",
        "key": "Custom mode creates a podcast-owned copy of queue placement, playback speed, skip controls, and chapter rules. Later global edits no longer flow into this podcast until you switch back to Global.",
        "location": {
          "startingColumn": 20,
          "startingLine": 279
        }
      },
      {
        "comment": "",
        "key": "Global mode keeps this podcast on the shared defaults. Switch to Custom only when this show should behave differently.",
        "location": {
          "startingColumn": 20,
          "startingLine": 280
        }
      },
      {
        "comment": "",
        "key": "Applied Right Now",
        "location": {
          "startingColumn": 17,
          "startingLine": 313
        }
      },
      {
        "comment": "",
        "key": "Inbox keeps new episodes out of Up Next. Top and Bottom place them directly into your selected playlist.",
        "location": {
          "startingColumn": 18,
          "startingLine": 389
        }
      },
      {
        "comment": "",
        "key": "This speed is used when playback starts. The player speed control also writes back here.",
        "location": {
          "startingColumn": 18,
          "startingLine": 410
        }
      },
      {
        "comment": "",
        "key": "When an episode is archived, its downloaded file is kept for this duration before automatic cleanup can remove it.",
        "location": {
          "startingColumn": 18,
          "startingLine": 434
        }
      },
      {
        "comment": "",
        "key": "New episodes go to",
        "location": {
          "startingColumn": 17,
          "startingLine": 362
        }
      },
      {
        "comment": "",
        "key": "Default playlist for auto-add",
        "location": {
          "startingColumn": 17,
          "startingLine": 377
        }
      },
      {
        "comment": "",
        "key": "Default speed",
        "location": {
          "startingColumn": 32,
          "startingLine": 404
        }
      },
      {
        "comment": "",
        "key": "Speeds through sustained quiet sections during normal audio episode playback.",
        "location": {
          "startingColumn": 14,
          "startingLine": 851
        }
      },
      {
        "comment": "",
        "key": "Low preserves longer pauses and word boundaries. Higher levels shorten more silence.",
        "location": {
          "startingColumn": 18,
          "startingLine": 872
        }
      },
      {
        "comment": "",
        "key": "Balances voice levels, removes low-frequency rumble, and controls loud peaks during normal audio playback.",
        "location": {
          "startingColumn": 14,
          "startingLine": 888
        }
      },
      {
        "comment": "",
        "key": "Reduce silence gaps",
        "location": {
          "startingColumn": 13,
          "startingLine": 841
        }
      },
      {
        "comment": "",
        "key": "Reduction level",
        "location": {
          "startingColumn": 17,
          "startingLine": 857
        }
      },
      {
        "comment": "",
        "key": "Voice enhancement",
        "location": {
          "startingColumn": 13,
          "startingLine": 878
        }
      },
      {
        "comment": "",
        "key": "Skip Durations",
        "location": {
          "startingColumn": 14,
          "startingLine": 895
        }
      },
      {
        "comment": "",
        "key": "These durations are used by the app player, shortcuts, and any external controls set to seconds.",
        "location": {
          "startingColumn": 14,
          "startingLine": 928
        }
      },
      {
        "comment": "",
