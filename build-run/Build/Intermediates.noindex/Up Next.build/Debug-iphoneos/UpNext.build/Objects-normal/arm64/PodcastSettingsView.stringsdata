        "location": {
          "startingColumn": 14,
          "startingLine": 934
        }
      },
      {
        "comment": "",
        "key": "Chapter mode uses previous/next chapter buttons when the playing episode has chapters. Without chapters, external controls fall back to the selected seconds.",
