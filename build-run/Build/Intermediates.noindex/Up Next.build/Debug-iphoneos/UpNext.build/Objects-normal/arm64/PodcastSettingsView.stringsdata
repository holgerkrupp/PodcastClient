        }
      },
      {
        "comment": "",
        "key": "When this is off, this podcast will not show the live event notification scheduling button. The global setting can still disable live notifications for every podcast.",
        "location": {
          "startingColumn": 20,
          "startingLine": 569
        }
      },
      {
        "comment": "",
        "key": "When this is off, this podcast will not show the live event notification scheduling button. The global setting can still disable live notifications for every podcast.",
        "location": {
          "startingColumn": 26,
          "startingLine": 595
        }
      },
      {
        "comment": "",
        "key": "This podcast supports live event information. Enable podcast-specific settings to override the global live notification setting.",
