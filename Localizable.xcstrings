    "Automatic for Period" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatisch für Zeitraum"
          }
        }
      }
    },
    "Automatic for Period picks the background from the data period, not from the day the shortcut runs. A shortcut running on 1 June with Previous Period uses May’s background." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatisch für Zeitraum wählt den Hintergrund aus dem Datenzeitraum, nicht vom Tag, an dem der Kurzbefehl läuft. Ein Kurzbefehl am 1. Juni mit Vorheriger Zeitraum nutzt den Mai-Hintergrund."
          }
        }
      }
    },
    "Automatic on-device transcriptions" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatische Transkriptionen auf dem Gerät"
          }
        }
      }
    },
    "Available actions now include: Resume Playback, Pause Playback, Bookmark This, Skip Forward, Skip Backward, Play Up Next, Play Next Up Next Episode, Move Current To End, Remove Current From Up Next, Refresh Podcasts, and Generate Podcast Share Image." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verfügbare Aktionen umfassen jetzt: Wiedergabe fortsetzen, Wiedergabe pausieren, Lesezeichen setzen, Vorwärts springen, Zurück springen, \"Als Nächstes\" abspielen, nächste \"Als Nächstes\"-Episode abspielen, aktuelle Episode ans Ende verschieben, aktuelle Episode aus \"Als Nächstes\" entfernen, Podcasts aktualisieren und Podcast-Teilen-Bild erstellen."
          }
        }
      }
    },
