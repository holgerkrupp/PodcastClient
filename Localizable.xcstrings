    "URL or Search" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "URL oder Suche"
          }
        }
      }
    },
    "Use \"Only while charging\" if you want automatic local transcription to wait for external power. While the app is open it reacts to charging changes, and in the background it can pick up eligible Up Next episodes once power is available." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende „Nur während des Ladevorgangs“, wenn die automatische lokale Transkription auf externe Stromversorgung warten soll. Während die App geöffnet ist, reagiert sie auf Ladeänderungen. Im Hintergrund kann sie geeignete „Als Nächstes“-Episoden aufnehmen, sobald Strom verfügbar ist."
          }
        }
      }
    },
    "Use at least %lld characters to search transcripts." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende mindestens %lld Zeichen, um Transkripte zu durchsuchen."
          }
        }
      }
    },
    "Use Custom" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Individuell verwenden"
          }
        }
      }
    },
    "Use global rules for all podcasts, or enable custom settings for one podcast when it needs its own behavior." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende globale Regeln für alle Podcasts oder aktiviere eigene Einstellungen für einen Podcast, wenn er eigenes Verhalten benötigt."
          }
        }
      }
    },
    "Use podcast-specific settings" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podcast-spezifische Einstellungen verwenden"
          }
        }
      }
    },
    "Use previous and next week buttons to change the date range" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende die Tasten für die vorherige und nächste Woche, um den Datumsbereich zu ändern."
          }
        }
      }
    },
    "Use rules for repeated segments like ads, intros, and credits. Each rule checks the chapter title with a match style such as contains or starts with." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende Regeln für wiederkehrende Segmente wie Werbung, Intros und Abspann. Jede Regel prüft den Kapiteltitel mit einem Übereinstimmungsstil wie „enthält“ oder „beginnt mit“."
          }
        }
      }
    },
    "Used when playback starts; the player speed control updates this value." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wird beim Start der Wiedergabe verwendet; die Geschwindigkeitssteuerung des Players aktualisiert diesen Wert."
