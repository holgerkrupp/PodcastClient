    },
    "The database total uses the real SQLite files on disk. The podcast and data-type breakdowns below estimate each record's share and scale that estimate to the actual database size." : {

    },
    "These settings are global only. They affect every podcast and cannot be customized per show." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Einstellungen sind nur global verfügbar. Sie betreffen jeden Podcast und können nicht pro Sendung angepasst werden."
          }
        }
      }
    },
    "These values apply across the app unless a podcast is switched to custom settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Werte gelten in der gesamten App, sofern ein Podcast nicht auf Individuell umgestellt wird."
          }
        }
      }
    },
    "This feed can be previewed, but it does not expose a reusable subscribe URL." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Feed kann in der Vorschau angesehen werden, stellt aber keine wiederverwendbare Abonnement-URL bereit."
          }
        }
      }
    },
    "This podcast currently has no standalone files stored outside the database." : {

    },
    "This podcast is already stored without a subscription. Open it to download or queue individual episodes, or subscribe to keep it refreshed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Podcast ist bereits ohne Abonnement gespeichert. Öffne ihn, um einzelne Episoden herunterzuladen oder in die Warteschlange zu legen, oder abonniere ihn, damit er aktuell gehalten wird."
          }
        }
      }
    },
    "This podcast stays in the database, but it is skipped by bulk refresh." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Podcast bleibt in der Datenbank, wird aber bei der Sammelaktualisierung übersprungen."
