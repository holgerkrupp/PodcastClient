    "Automatic for Period" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatisch für Zeitraum"
          }
        }
      }
    },
    "Automatic for Period picks the background from the data period, not from the day the shortcut runs. A shortcut running on 1 June with Previous Period uses May’s background." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Automatisch für Zeitraum“ wählt den Hintergrund anhand des Datenzeitraums aus, nicht anhand des Tages, an dem der Kurzbefehl ausgeführt wird. Ein Kurzbefehl, der am 1. Juni mit „Vorheriger Zeitraum“ ausgeführt wird, verwendet den Mai-Hintergrund."
          }
        }
      }
    },
    "Automatic on-device transcriptions" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatische Transkriptionen auf dem Gerät"
          }
        }
      }
    },
    "Automatically start the next queue item when an episode finishes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starte automatisch den nächsten Eintrag in der Warteschlange, wenn eine Episode endet."
          }
        }
