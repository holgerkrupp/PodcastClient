      }
    },
    "%lld file%@ (%@) are currently protected by archive retention settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Dateien %1$lld%2$@ (%3$@) sind derzeit durch Archivaufbewahrungseinstellungen geschützt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld file%2$@ (%3$@) are currently protected by archive retention settings."
          }
        }
      }
    },
    "%lld file%@ (%@) can be removed without deleting downloads needed for Up Next or archived episodes still inside their retention window." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die %1$lld-Datei%2$@ (%3$@) kann entfernt werden, ohne dass für Up Next erforderliche Downloads oder archivierte Episoden gelöscht werden, die sich noch im Aufbewahrungsfenster befinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld file%2$@ (%3$@) can be removed without deleting downloads needed for Up Next or archived episodes still inside their retention window."
