    "%lld file%@ (%@) are currently protected because their episodes are in Up Next." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Datei %1$lld%2$@ (%3$@) ist derzeit geschützt, da sich ihre Episoden in „Als Nächstes“ befinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld file%2$@ (%3$@) are currently protected because their episodes are in Up Next."
